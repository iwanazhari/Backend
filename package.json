{
  "name": "backend-starter-kit",
  "version": "5.0.0",
  "description": "Production-ready TypeScript backend starter kit with Prisma, WebSocket, Swagger, and Zero Trust Security",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "pm2 start pm2.config.js",
    "start:local": "node dist/index.js",
    "dev": "tsx watch src/index.js",
    "dev:legacy": "nodemon --exec tsx src/index.js",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --watch",
    "lint": "eslint src/**/*.ts tests/**/*.ts scripts/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts scripts/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "npm run test -- --watch",
    "test:e2e": "npm run test -- tests/e2e --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --seed",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate",
    "swagger:generate": "tsx scripts/generate-swagger.ts",
    "swagger:watch": "nodemon --watch src -e ts,json --exec 'npm run swagger:generate'",
    "generate:module": "tsx scripts/generate-all.ts",
    "generate:controller": "tsx scripts/generate-controller.ts",
    "generate:service": "tsx scripts/generate-service.ts",
    "generate:repository": "tsx scripts/generate-repository.ts",
    "generate:prisma-model": "tsx scripts/generate-prisma-model.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "commitlint": "commitlint --edit"
  },
  "keywords": [
    "backend",
    "starter-kit",
    "clean-architecture",
    "express",
    "nodejs",
    "typescript",
    "esm",
    "prisma",
    "websocket",
    "swagger",
    "zero-trust",
    "boilerplate"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "redis": "^4.6.11",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "dayjs": "^1.11.10",
    "axios": "^1.6.2",
    "node-cron": "^3.0.3",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "yamljs": "^0.3.0",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.14.202",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "faker": "^5.5.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "prisma/schema.prisma": [
      "prisma format"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
