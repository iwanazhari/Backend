# Test Environment Configuration
# Copy this to .env.test and update values

# Application
NODE_ENV=test
APP_NAME=Backend Starter Kit (Test)
APP_PORT=3001
APP_URL=http://localhost:3001

# Test Database (Prisma) - Separate from dev/prod
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter_kit_test?schema=public

# Redis (Test database or same as dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PASETO V4 (Required - use different keys for test)
# Generate with: npm run generate:paseto-key
PASETO_SECRET_KEY=test-secret-key-must-be-32-bytes-minimum!!
PASETO_EXPIRE=15m
PASETO_REFRESH_EXPIRE=7d

# JWT (Deprecated - for backward compat only, DO NOT USE)
JWT_SECRET=deprecated-use-paseto-instead
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=deprecated-use-paseto-instead
JWT_REFRESH_EXPIRE=30d

# Logging
LOG_LEVEL=debug
LOG_FILE_MAX_FILES=5

# Rate Limiting (faster for testing)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads-test
