{
  "name": "lockkit",
  "version": "1.0.0",
  "description": "Production-ready access control toolkit - Zero Trust Security, Enterprise-Ready, 100% Test Coverage",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "lockkit": "./src/cli/index.js",
    "lk": "./src/cli/index.js"
  },
  "keywords": [
    "lockkit",
    "authentication",
    "access-control",
    "security",
    "zero-trust",
    "enterprise",
    "express",
    "nestjs",
    "fastify",
    "paseto",
    "oauth",
    "sso",
    "webauthn",
    "rbac",
    "abac"
  ],
  "scripts": {
    "start": "pm2 start pm2.config.ts",
    "start:local": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:legacy": "nodemon --exec tsx src/index.ts",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --watch",
    "lint": "eslint src/**/*.ts tests/**/*.ts scripts/**/*.ts --ext .ts,.cts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts scripts/**/*.ts --ext .ts,.cts --fix",
    "lint:arch": "node scripts/architecture-lint.js",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:ui": "vitest --ui",
    "test:vitest:coverage": "vitest run --coverage",
    "test:manual": "tsx tests/manual/test-paseto.js",
    "test:manual:jose": "tsx tests/manual/test-jose-simple.js",
    "test:manual:service": "tsx tests/manual/test-token-service.js",
    "test:manual:complete": "tsx tests/manual/test-token-complete.js",
    "test:manual:final": "tsx tests/manual/test-token-final.js",
    "test:manual:magiclink": "tsx tests/manual/test-magiclink.js",
    "test:manual:otp": "tsx tests/manual/test-otp.js",
    "test:manual:oauth": "tsx tests/manual/test-oauth.js",
    "test:manual:session": "tsx tests/manual/test-session.js",
    "test:integration:express": "tsx tests/integration/adapters/test-express.js",
    "test:integration:nestjs": "tsx tests/integration/adapters/test-nestjs.js",
    "test:integration:fastify": "tsx tests/integration/adapters/test-fastify.js",
    "test:cli": "node src/cli/index.js",
    "cli": "tsx src/cli/index.js",
    "test:e2e": "tsx tests/e2e/test-auth-flows.js",
    "test:security": "tsx tests/security/test-pentest.js",
    "test:advanced": "tsx tests/manual/test-webauthn-rbac-abac.js",
    "test:sso": "tsx tests/manual/test-sso.js",
    "test:impossible-travel": "tsx tests/manual/test-impossible-travel.js",
    "test:account-lockout": "tsx tests/manual/test-account-lockout.js",
    "test:all-remaining": "tsx tests/manual/test-all-remaining-features.js",
    "test:jest:e2e": "npm run test -- tests/e2e --runInBand",
    "test:watch": "npm run test -- --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --seed",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate",
    "swagger:generate": "tsx scripts/generate-swagger.ts",
    "swagger:watch": "nodemon --watch src -e ts,json --exec 'npm run swagger:generate'",
    "generate:paseto-key": "tsx scripts/generate-paseto-key.ts",
    "generate:module": "tsx scripts/generate-all.ts",
    "generate:controller": "tsx scripts/generate-controller.ts",
    "generate:service": "tsx scripts/generate-service.ts",
    "generate:repository": "tsx scripts/generate-repository.ts",
    "generate:prisma-model": "tsx scripts/generate-prisma-model.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "commitlint": "commitlint --edit"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pm2": "^5.3.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.1",
    "socket.io": "^4.6.1",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "v4": "^0.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/eslint": "^9.6.1",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-node": "^11.1.0",
    "faker": "^5.5.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "prisma/schema.prisma": [
      "prisma format"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
