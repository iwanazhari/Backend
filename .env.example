# Application
NODE_ENV=development
APP_NAME=Backend Starter Kit
APP_PORT=3000
APP_URL=http://localhost:3000

# Database (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter_kit_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (Deprecated - keeping for backward compatibility only)
# DO NOT USE - PASETO is now the default
JWT_SECRET=deprecated-use-paseto-instead
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=deprecated-use-paseto-instead
JWT_REFRESH_EXPIRE=30d

# PASETO V4 (Required - Platform-Agnostic Security Tokens)
# Generate secure key: node scripts/generate-paseto-key.js
# Key must be at least 32 bytes
PASETO_SECRET_KEY=your-32-byte-paseto-secret-key-change-in-production
PASETO_EXPIRE=15m
PASETO_REFRESH_EXPIRE=7d

# Logging
LOG_LEVEL=debug
LOG_FILE_MAX_FILES=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# PM2 (Production)
PM2_INSTANCES=4
PM2_APP_NAME=backend-starter-kit
PM2_LOG_FILE=logs/pm2.log
PM2_ERROR_FILE=logs/pm2-error.log

# External APIs (examples)
# API_KEY=your-api-key
